# Fetched wrap sources (provisioned by meson setup, not committed).
# packagefiles/ IS committed: meson patch_directory sources (e.g. monocypher).
*/
!packagefiles/
!packagefiles/**

# Transitive .wrap files are auto-generated by `meson subprojects download`
# from the parent wraps' [wrap-redirect]/[provide] sections. Ignore them all
# and re-allow only the wraps we author and commit.
*.wrap
!frida-core.wrap
!frida-gum.wrap
!frida.wrap
!libgee.wrap
!libnice.wrap
!libpsl.wrap
!libsoup.wrap
!monocypher.wrap
!quickjs.wrap
!selinux.wrap
!tinycc.wrap
!usrsctp.wrap
